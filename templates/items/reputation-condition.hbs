<section class="gs-item-sheet__wrapper">
<form class="gs-item-sheet__form" autocomplete="off">
  <header class="gs-item-sheet__header">
    <div class="gs-item-sheet__header-row">
      <span class="gs-item-sheet__eyebrow">{{localize "GOODSOCIETY.item.reputationCondition.eyebrow"}}</span>
      <button type="button"
              class="gs-btn-status{{#if system.active}} gs-btn-status--active{{/if}}"
              data-action="toggleActive"
              title="{{localize "GOODSOCIETY.item.reputationCondition.toggleActive"}}">
        {{#if system.active}}{{localize "GOODSOCIETY.item.reputationCondition.active"}}{{else}}{{localize "GOODSOCIETY.item.reputationCondition.inactive"}}{{/if}}
      </button>
    </div>
    <input class="gs-item-sheet__name"
           type="text"
           name="name"
           value="{{document.name}}"
           placeholder="{{localize "GOODSOCIETY.item.reputationCondition.namePlaceholder"}}" />
  </header>

  <div class="gs-item-sheet__body">

    {{!-- Polarity --}}
    <div class="gs-item-sheet__field">
      <span class="gs-item-sheet__label">{{localize "GOODSOCIETY.polarity.label"}}</span>
      <div class="gs-item-sheet__polarity-row">
        <button type="button"
                class="gs-btn-polarity gs-btn-polarity--positive{{#if (eq system.polarity 'positive')}} gs-btn-polarity--active{{/if}}"
                data-action="setPolarity"
                data-polarity="positive">
          {{localize "GOODSOCIETY.polarity.positive"}}
        </button>
        <button type="button"
                class="gs-btn-polarity gs-btn-polarity--negative{{#if (eq system.polarity 'negative')}} gs-btn-polarity--active{{/if}}"
                data-action="setPolarity"
                data-polarity="negative">
          {{localize "GOODSOCIETY.polarity.negative"}}
        </button>
      </div>
    </div>

    {{!-- Archetype gating — toggle chips. No selection = universal. --}}
    <div class="gs-item-sheet__field">
      <span class="gs-item-sheet__label">{{localize "GOODSOCIETY.item.reputationCondition.archetypesLabel"}}</span>
      <div class="gs-item-sheet__archetype-row">
        {{#each archetypeChoices}}
          <button type="button"
                  class="gs-btn-flag{{#if selected}} gs-btn-flag--active{{/if}}"
                  data-action="toggleArchetype"
                  data-archetype="{{id}}">
            {{label}}
          </button>
        {{/each}}
      </div>
      <p class="gs-item-sheet__hint">
        {{#if isUniversal}}
          {{localize "GOODSOCIETY.item.reputationCondition.archetypesUniversal"}}
        {{else}}
          {{localize "GOODSOCIETY.item.reputationCondition.archetypesHint"}}
        {{/if}}
      </p>
    </div>

    {{!-- Description — read-only enriched render + ✎ edit button. The v13
         {{editor}} helper doesn't open in ApplicationV2; the button opens a
         shared DialogV2 rich-text editor instead. --}}
    <div class="gs-item-sheet__field">
      <div class="gs-item-sheet__label-row">
        <span class="gs-item-sheet__label">{{localize "GOODSOCIETY.item.reputationCondition.description"}}</span>
        <button type="button" class="gs-item-sheet__edit-btn"
                data-action="editDescription"
                title="{{localize 'GOODSOCIETY.common.edit'}}"
                aria-label="{{localize 'GOODSOCIETY.common.edit'}}">
          <span aria-hidden="true">✎</span>
        </button>
      </div>
      <div class="gs-item-sheet__description-body">
        {{#if enrichedDescription}}
          {{{enrichedDescription}}}
        {{else}}
          <p class="gs-item-sheet__description-placeholder"><em>{{localize "GOODSOCIETY.common.noDescription"}}</em></p>
        {{/if}}
      </div>
    </div>

    {{!-- Source tag IDs (read-only count for now; full tag picker is B-5) --}}
    {{#if system.sourceTagIds.length}}
    <div class="gs-item-sheet__field">
      <span class="gs-item-sheet__label">{{localize "GOODSOCIETY.item.reputationCondition.sourceTags"}}</span>
      <p class="gs-item-sheet__helper">
        {{system.sourceTagIds.length}} {{localize "GOODSOCIETY.item.reputationCondition.sourceTagsLinked"}}
      </p>
    </div>
    {{/if}}

  </div>
</form>
</section>
