{{!-- Speaking-As switcher — injected above the chat input by the renderChatInput hook.
     Click the speaker pill to open a popover; click an option to switch.
     Per docs/design/10-chat-cards.md §"Speaking-As switcher". --}}
<div class="gs-speaking-as" data-active-actor="{{activeSpeakerActorId}}" data-active-persona="{{activePersonaId}}">
  <span class="gs-speaking-as__label">{{localize "GOODSOCIETY.speakingAs.label"}}</span>

  <button type="button" class="gs-speaking-as__pill" aria-haspopup="listbox" aria-expanded="false">
    <span class="gs-speaking-as__pill-name">
      {{#if speakerLabel}}{{speakerLabel}}{{else}}— {{localize "GOODSOCIETY.speakingAs.none"}} —{{/if}}
    </span>
    <span class="gs-speaking-as__pill-chevron" aria-hidden="true">▾</span>
  </button>

  <div class="gs-speaking-as__popover" role="listbox" hidden>
    <button type="button" class="gs-speaking-as__option" role="option" data-actor-id="" data-persona-id="">
      — {{localize "GOODSOCIETY.speakingAs.none"}} —
    </button>
    {{#each myMajors as |actor|}}
      <button type="button"
              class="gs-speaking-as__option {{#if (eq ../activeSpeakerActorId actor.id)}}is-active{{/if}}"
              role="option"
              data-actor-id="{{actor.id}}"
              data-persona-id="">
        {{actor.name}}
      </button>
      {{#each actor.system.personas as |persona|}}
        <button type="button"
                class="gs-speaking-as__option gs-speaking-as__option--persona {{#if (and (eq ../../activeSpeakerActorId ../actor.id) (eq ../../activePersonaId persona.id))}}is-active{{/if}}"
                role="option"
                data-actor-id="{{../actor.id}}"
                data-persona-id="{{persona.id}}">
          ↳ {{persona.name}}
        </button>
      {{/each}}
    {{/each}}
  </div>
</div>
