{{!-- Event Timeline row partial. Receives the event as `this`, plus explicit
     partial params: stage, editingId, isGM, choices.

     Stage drives which action buttons appear:
       coming-soon → "Move to Today" (GM)
       today       → "Conclude" + "← back to Coming Soon" (GM)
       past        → no stage actions (read-only history)

     All edit / delete buttons are GM-only across stages. --}}
{{#if (eq id editingId)}}
  {{!-- Edit form (GM only — non-GM never has editingId set) --}}
  <div class="gs-event-timeline__row gs-event-timeline__row--editing" data-event-id="{{id}}">
    <div class="gs-event-timeline__form">
      <div class="gs-event-timeline__form-row">
        <label class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.titleLabel"}}</label>
        <input type="text" data-evt-field="title" data-event-id="{{id}}" value="{{title}}" class="gs-event-timeline__input" />
      </div>
      <div class="gs-event-timeline__form-row">
        <label class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.dateLabelLabel"}}</label>
        <input type="text" data-evt-field="dateLabel" data-event-id="{{id}}" value="{{dateLabel}}" class="gs-event-timeline__input" placeholder="{{localize "GOODSOCIETY.eventTimeline.dateLabelPlaceholder"}}" />
      </div>
      <div class="gs-event-timeline__form-row">
        <label class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.descriptionLabel"}}</label>
        <textarea data-evt-field="description" data-event-id="{{id}}" class="gs-event-timeline__textarea" rows="3">{{description}}</textarea>
      </div>
      <div class="gs-event-timeline__form-row gs-event-timeline__form-row--vis">
        <span class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.visibilityLabel"}}</span>
        {{#each choices}}
          <label class="gs-event-timeline__radio">
            <input type="radio" name="gs-evt-edit-visibility-{{../id}}" data-evt-field="visibility" data-event-id="{{../id}}" value="{{value}}" {{#if (eq value ../visibility)}}checked{{/if}} />
            <span>{{label}}</span>
          </label>
        {{/each}}
      </div>
      <div class="gs-event-timeline__form-actions">
        <button type="button" class="gs-btn gs-btn--ghost"   data-action="editEventCancel">{{localize "GOODSOCIETY.eventTimeline.cancel"}}</button>
        <button type="button" class="gs-btn gs-btn--primary" data-action="editEventSave" data-event-id="{{id}}">{{localize "GOODSOCIETY.eventTimeline.save"}}</button>
      </div>
    </div>
  </div>
{{else}}
  {{!-- Display row --}}
  <div class="gs-event-timeline__row gs-event-timeline__row--{{stage}} {{#if isHidden}}gs-event-timeline__row--hidden{{/if}}" data-event-id="{{id}}">
    <div class="gs-event-timeline__row-header">
      {{#if showsDateLabel}}
        <span class="gs-event-timeline__row-date">{{dateLabel}}</span>
      {{/if}}
      {{#if isHidden}}
        <span class="gs-event-timeline__row-vis-badge">{{visibilityLabel}}</span>
      {{/if}}
      {{#if isGM}}
        <div class="gs-event-timeline__row-actions">
          <button type="button" class="gs-event-timeline__icon-btn" data-action="editEventOpen" data-event-id="{{id}}" title="{{localize "GOODSOCIETY.eventTimeline.editHint"}}" aria-label="{{localize "GOODSOCIETY.eventTimeline.edit"}}">✎</button>
          <button type="button" class="gs-event-timeline__icon-btn gs-event-timeline__icon-btn--danger" data-action="deleteEvent" data-event-id="{{id}}" title="{{localize "GOODSOCIETY.eventTimeline.deleteHint"}}" aria-label="{{localize "GOODSOCIETY.eventTimeline.delete"}}">✕</button>
        </div>
      {{/if}}
    </div>
    <div class="gs-event-timeline__row-title">{{title}}</div>
    {{#if description}}
      <p class="gs-event-timeline__row-description">{{description}}</p>
    {{/if}}

    {{!-- Scene chip — shown on today + past rows when an associated scene exists --}}
    {{#if sceneId}}
      <div class="gs-event-timeline__row-scene">
        <span class="gs-event-timeline__row-scene-label">{{localize "GOODSOCIETY.eventTimeline.sceneLabel"}}</span>
        {{#if sceneFound}}
          <button type="button" class="gs-event-timeline__row-scene-link" data-action="openScene" data-scene-id="{{sceneId}}" title="{{localize "GOODSOCIETY.eventTimeline.openSceneHint"}}">{{sceneName}}</button>
        {{else}}
          <span class="gs-event-timeline__row-scene-missing">{{localize "GOODSOCIETY.eventTimeline.sceneMissing"}}</span>
        {{/if}}
      </div>
    {{/if}}

    {{!-- Stage actions (GM only) --}}
    {{#if isGM}}
      {{#if (eq stage "coming-soon")}}
        <div class="gs-event-timeline__row-stage-actions">
          <button type="button" class="gs-btn gs-btn--sm gs-btn--primary" data-action="promoteEventBtn" data-event-id="{{id}}">
            {{localize "GOODSOCIETY.eventTimeline.promoteBtn"}} →
          </button>
        </div>
      {{else if (eq stage "today")}}
        <div class="gs-event-timeline__row-stage-actions">
          <button type="button" class="gs-btn gs-btn--sm gs-btn--ghost" data-action="revertEventBtn" data-event-id="{{id}}" title="{{localize "GOODSOCIETY.eventTimeline.revertHint"}}">
            ← {{localize "GOODSOCIETY.eventTimeline.revertBtn"}}
          </button>
          <button type="button" class="gs-btn gs-btn--sm gs-btn--primary" data-action="concludeEventBtn" data-event-id="{{id}}">
            {{localize "GOODSOCIETY.eventTimeline.concludeBtn"}} ✓
          </button>
        </div>
      {{/if}}
    {{/if}}
  </div>
{{/if}}
