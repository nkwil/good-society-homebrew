{{!-- Major row in the My Characters Dock — wrapped in .gs-themed[data-theme]
     so the actor's brand/palette applies to portrait, name, and resolve pips.
     Click anywhere on the row to open the sheet (delegated handler). --}}
<div class="gs-themed gs-dock__row gs-dock__row--major"
     data-theme="{{theme}}"
     data-actor-id="{{id}}"
     role="button"
     tabindex="0"
     aria-label="{{name}}, Major character{{#if showPersonaLine}}, as {{speakerName}}{{/if}}. Click to open sheet.">
  <div class="gs-dock__portrait" aria-hidden="true">
    {{#if portraitUrl}}
      <img src="{{portraitUrl}}" alt="" />
    {{else}}
      <span class="gs-dock__portrait-initial">{{initial}}</span>
    {{/if}}
  </div>
  <div class="gs-dock__row-stack">
    <div class="gs-dock__row-name">{{name}}</div>
    {{#if title}}
      <div class="gs-dock__row-title"><em>{{title}}</em></div>
    {{/if}}
    {{#if showPersonaLine}}
      <div class="gs-dock__row-persona">{{localize "GOODSOCIETY.dock.asPersona"}} {{speakerName}}</div>
    {{/if}}
    <div class="gs-dock__row-state">
      <div class="gs-dock__resolve">
        {{#each resolvePips as |filled|}}
          <span class="gs-dock__resolve-pip {{#if filled}}filled{{/if}}"></span>
        {{/each}}
      </div>
      <span class="gs-dock__mt {{#if mtActive}}is-on{{/if}}">MT</span>
      <span class="gs-dock__monologue {{#if monologueAvailable}}is-available{{/if}}"
            title="{{#if monologueAvailable}}{{localize 'GOODSOCIETY.dock.monologueAvailable'}}{{else}}{{localize 'GOODSOCIETY.dock.monologueSpent'}}{{/if}}"
            aria-hidden="true"></span>
    </div>

    {{!-- Active conditions sub-rail — post-MVP §3.3 / §10.4. Hidden when empty.
         Dock rows are denser than dashboard rows, so the rail caps at one line
         with horizontal scroll instead of wrapping (per §10.4 open-question
         resolution). --}}
    {{#if hasConditions}}
      <div class="gs-dock__row-conditions" aria-label="{{localize 'GOODSOCIETY.dock.conditionsRailLabel'}}">
        {{#each positiveConditions}}
          <span class="gs-dock__condition-pill gs-dock__condition-pill--positive"
                data-condition-id="{{id}}" title="{{name}}">▲ {{name}}</span>
        {{/each}}
        {{#each negativeConditions}}
          <span class="gs-dock__condition-pill gs-dock__condition-pill--negative"
                data-condition-id="{{id}}" title="{{name}}">▼ {{name}}</span>
        {{/each}}
      </div>
    {{/if}}
  </div>
</div>
