<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" width="70" height="70" />
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Name" /></h1>
      <span style="font-size: 0.8em; opacity: 0.6;">{{actor.type}} — sheet coming in Phase 1</span>
    </div>
  </header>
</form>
