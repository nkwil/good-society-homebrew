{{!-- Connection sheet — scene info PART (public tags + hover summary). --}}
<section class="gs-connection-sheet__scene">
  <div class="gs-connection-sheet__scene-grid">

    <div class="gs-connection-sheet__scene-col">
      <div class="gs-connection-sheet__section-row">
        <header class="gs-section-header" data-tooltip-key="publicTags">
          {{localize "GOODSOCIETY.connection.publicTags"}}
        </header>
        <button class="gs-btn gs-btn--secondary gs-btn--sm"
                type="button"
                data-action="addPublicTag">+</button>
      </div>
      <div class="gs-connection-sheet__tag-list">
        {{#each publicTags}}
          <span class="gs-scene-tag">{{this}}</span>
        {{/each}}
        {{#unless publicTags.length}}
          <span class="gs-connection-sheet__empty-state">
            {{localize "GOODSOCIETY.connection.noTags"}}
          </span>
        {{/unless}}
      </div>
    </div>

    <div class="gs-connection-sheet__scene-col">
      <header class="gs-section-header" data-tooltip-key="hoverSummary">
        {{localize "GOODSOCIETY.connection.hoverSummary"}}
      </header>
      {{!-- Post-MVP §10.2 subtitle line — short italic descriptor (~50 chars). --}}
      <input class="gs-connection-sheet__hover-subtitle"
             type="text"
             name="system.sceneInfo.subtitle"
             placeholder="{{localize "GOODSOCIETY.connection.hoverSubtitlePlaceholder"}}"
             value="{{system.sceneInfo.subtitle}}" />
      <textarea class="gs-connection-sheet__hover-summary"
                name="system.sceneInfo.hoverSummary"
                placeholder="{{localize "GOODSOCIETY.connection.hoverSummaryPlaceholder"}}"
                rows="3">{{hoverSummary}}</textarea>
    </div>

  </div>
</section>
