{{!-- Family sheet — GM notes PART. Per docs/design/14-family-sheet.md §"GM Notes block". --}}
<section class="gs-family-sheet__notes">

  <div class="gs-family-sheet__section-row">
    <div class="gs-family-sheet__notes-label">
      <span class="gs-gm-pill">GM</span>
      <header class="gs-section-header" data-tooltip-key="familyNotes">
        {{localize "GOODSOCIETY.family.notes"}}
      </header>
      <button type="button" class="gs-item-sheet__edit-btn"
              data-action="editNotes"
              title="{{localize 'GOODSOCIETY.common.edit'}}"
              aria-label="{{localize 'GOODSOCIETY.common.edit'}}">
        <span aria-hidden="true">✎</span>
      </button>
    </div>
    <button class="gs-visibility-flag gs-visibility-flag--{{system.visibility.notes}}"
            type="button"
            data-action="toggleVisibility"
            data-field="notes">
      {{system.visibility.notes}}
    </button>
  </div>

  {{!-- Notes — read-only enriched render; editing opens a DialogV2 via the
       ✎ button. v13's {{editor}} helper doesn't open in ApplicationV2. --}}
  <div class="gs-family-sheet__notes-body gs-item-sheet__description-body">
    {{#if enrichedNotes}}
      {{{enrichedNotes}}}
    {{else}}
      <p class="gs-item-sheet__description-placeholder"><em>{{localize "GOODSOCIETY.common.noDescription"}}</em></p>
    {{/if}}
  </div>

</section>
