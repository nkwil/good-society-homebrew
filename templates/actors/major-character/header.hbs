<header class="gs-major-sheet__header">

  {{!-- Side panel: portrait + bio chips + persona switcher --}}
  <div class="gs-major-sheet__side">

    {{#if portraitUrl}}
      <img class="gs-major-sheet__portrait" src="{{portraitUrl}}" alt="{{displayName}}" />
    {{else}}
      <div class="gs-major-sheet__portrait-fallback">{{portraitInitial}}</div>
    {{/if}}

    <div class="gs-major-sheet__bio-chips">
      {{#if system.bio.age}}age {{system.bio.age}}{{/if}}
      {{#if system.bio.peerage}}<br>{{system.bio.peerage}}{{/if}}
    </div>

    <hr class="gs-hairline gs-major-sheet__side-rule">

    <span class="gs-persona-picker__eyebrow">{{localize "GOODSOCIETY.personaSwitcher.eyebrow"}}</span>
    <button type="button" class="gs-persona-picker__trigger" data-action="openPersonaSwitcher"
            title="{{localize "GOODSOCIETY.personaSwitcher.triggerHint"}}">
      {{#if activePersonaExplicit}}{{displayName}} ▾{{else}}{{localize "GOODSOCIETY.personaSwitcher.trueIdentity"}} ▾{{/if}}
    </button>

  </div>

  {{!-- Main column: eyebrow row, character name, role/title, tab nav --}}
  <div class="gs-major-sheet__main">

    <div class="gs-major-sheet__eyebrow">
      <span class="gs-major-sheet__eyebrow-left">major character</span>
      <select class="gs-major-sheet__theme-select" name="system.theme"
              title="{{localize "GOODSOCIETY.personaSwitcher.themeSelectHint"}}">
        <option value="rose"    {{#if (eq system.theme "rose"   )}}selected{{/if}}>{{localize "GOODSOCIETY.theme.rose"}}</option>
        <option value="roger"   {{#if (eq system.theme "roger"  )}}selected{{/if}}>{{localize "GOODSOCIETY.theme.roger"}}</option>
        <option value="mags"    {{#if (eq system.theme "mags"   )}}selected{{/if}}>{{localize "GOODSOCIETY.theme.mags"}}</option>
        <option value="avril"   {{#if (eq system.theme "avril"  )}}selected{{/if}}>{{localize "GOODSOCIETY.theme.avril"}}</option>
        <option value="dixon"   {{#if (eq system.theme "dixon"  )}}selected{{/if}}>{{localize "GOODSOCIETY.theme.dixon"}}</option>
        <option value="clayton" {{#if (eq system.theme "clayton")}}selected{{/if}}>{{localize "GOODSOCIETY.theme.clayton"}}</option>
      </select>
    </div>

    {{!-- Display name = persona name if active (including primary-persona fallback
         when activePersonaId is empty), else actor name. When a persona is driving
         the displayName, the input is BOTH readonly AND stripped of its name="name"
         attribute — readonly stops the user typing into it, the missing name
         attribute stops form-submit from writing the displayed persona name back
         to actor.name. The earlier check used `activePersonaId` only, which had a
         hole: when activePersonaId was '' but personas existed, the data-model
         getter resolved displayName to the primary persona while readonly stayed
         off, so form-submit silently renamed the actor to the persona's name.
         To rename the actor, clear the persona via the dropdown first. --}}
    <input class="gs-major-sheet__name"
           type="text"
           {{#unless hasActivePersona}}name="name"{{/unless}}
           value="{{displayName}}"
           {{#if hasActivePersona}}readonly title="To rename the actor, clear the persona selection first."{{/if}}
           placeholder="{{localize 'GOODSOCIETY.sheet.namePlaceholder'}}" />

    <p class="gs-major-sheet__role">{{roleTitle}}</p>

    <hr class="gs-hairline gs-major-sheet__main-rule">

    {{!-- Tab nav — ApplicationV2 built-in tab handling via data-action="tab" --}}
    <nav class="tabs gs-major-sheet__nav">
      <button type="button"
              class="gs-major-sheet__tab-btn {{#if (eq tabGroups.sheet 'public')}}active{{/if}}"
              data-action="tab"
              data-group="sheet"
              data-tab="public">
        {{localize "GOODSOCIETY.tab.public"}}
      </button>
      <button type="button"
              class="gs-major-sheet__tab-btn {{#if (eq tabGroups.sheet 'private')}}active{{/if}}"
              data-action="tab"
              data-group="sheet"
              data-tab="private">
        {{localize "GOODSOCIETY.tab.private"}}
      </button>
    </nav>

  </div>

</header>
