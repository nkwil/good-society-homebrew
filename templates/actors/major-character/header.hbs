{{!--
  Major Character header — post-MVP §4 dossier cameo.

  Layout: cameo (left, ~140px) + main column. Cameo carries the token-based
  profile image (per `profilePic()` resolution; persona-aware), bio chips,
  and the persona-switcher pill (post-MVP §8.4 unified primitive). Main
  column carries the standalone eyebrow row (theme swatches + role tag),
  the character name with Lavishly Yours first-letter ornament, the
  derived role/title line, and the tab nav.
--}}
<header class="gs-major-sheet__header">

  {{!-- Cameo column: token image + bio chips + persona switcher --}}
  <div class="gs-major-sheet__cameo">

    <button type="button"
            class="gs-major-sheet__cameo-frame"
            data-action="pickToken"
            title="{{localize "GOODSOCIETY.cameo.pickTokenTitle"}}">
      {{#if profilePicUrl}}
        <img class="gs-major-sheet__cameo-img" src="{{profilePicUrl}}" alt="{{displayName}}" />
      {{else}}
        <span class="gs-major-sheet__cameo-initial">{{portraitInitial}}</span>
      {{/if}}
    </button>

    <div class="gs-major-sheet__bio-chips">
      {{#if system.bio.age}}<span class="gs-major-sheet__bio-chip">age {{system.bio.age}}</span>{{/if}}
      {{#if archetypeLabel}}<span class="gs-major-sheet__bio-chip">{{archetypeLabel}}</span>{{/if}}
      {{#if peerageLabel}}<span class="gs-major-sheet__bio-chip gs-major-sheet__bio-chip--muted">{{peerageLabel}}</span>{{/if}}
    </div>

    {{!-- Persona switcher pill — post-MVP §8.4 unified primitive. The
         popover behavior is handled by the existing delegated listener
         in module/apps/persona-switcher-popover.js. --}}
    {{> persona-switcher actor=actor displayName=displayName activePersonaExplicit=activePersonaExplicit}}

  </div>

  {{!-- Main column --}}
  <div class="gs-major-sheet__main">

    {{!-- Eyebrow row: standalone "major character" eyebrow + theme swatches.
         Theme swatches replace the legacy <select> — clicking a swatch fires
         setTheme action which writes actor.system.theme. --}}
    <div class="gs-major-sheet__eyebrow-row">
      <span class="gs-eyebrow gs-eyebrow--subdued">{{localize "GOODSOCIETY.sheet.majorEyebrow"}}</span>
      <div class="gs-major-sheet__theme-swatches" role="radiogroup"
           aria-label="{{localize 'GOODSOCIETY.personaSwitcher.themeSelectHint'}}">
        {{#each themeRegistry}}
          <button type="button"
                  class="gs-major-sheet__theme-swatch {{#if isActive}}is-active{{/if}}"
                  data-action="setTheme"
                  data-theme-id="{{id}}"
                  style="--swatch-color: {{swatchColor}};"
                  title="{{label}}"
                  aria-label="{{label}}"
                  aria-checked="{{isActive}}"
                  role="radio"></button>
        {{/each}}
      </div>
    </div>

    {{!-- Character name with Lavishly Yours-faced first-letter decoration —
         the sole §4.2 ornament-face exception. The decorative initial is a
         purely visual `::before`-style span on the wrapper; the editable
         input still carries the FULL displayName so form-submit writes the
         complete name. CSS clips the input's first character behind the
         decorative initial so they align visually rather than duplicating. --}}
    <div class="gs-major-sheet__name-wrap"
         data-name-initial="{{firstLetter displayName}}">
      <input class="gs-major-sheet__name"
             type="text"
             {{#unless hasActivePersona}}name="name"{{/unless}}
             value="{{displayName}}"
             {{#if hasActivePersona}}readonly title="To rename the actor, clear the persona selection first."{{/if}}
             placeholder="{{localize 'GOODSOCIETY.sheet.namePlaceholder'}}" />
    </div>

    <p class="gs-major-sheet__role">{{roleTitle}}</p>

    <hr class="gs-hairline gs-major-sheet__main-rule">

    {{!-- Tab nav — ApplicationV2 built-in tab handling via data-action="tab" --}}
    <nav class="tabs gs-major-sheet__nav">
      <button type="button"
              class="gs-major-sheet__tab-btn {{#if (eq tabGroups.sheet 'public')}}active{{/if}}"
              data-action="tab"
              data-group="sheet"
              data-tab="public">
        {{localize "GOODSOCIETY.tab.public"}}
      </button>
      <button type="button"
              class="gs-major-sheet__tab-btn {{#if (eq tabGroups.sheet 'private')}}active{{/if}}"
              data-action="tab"
              data-group="sheet"
              data-tab="private">
        {{localize "GOODSOCIETY.tab.private"}}
      </button>
    </nav>

  </div>

</header>
