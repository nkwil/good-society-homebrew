{{!-- Inner Conflict completion ceremony card — themed, centered, celebratory.
     Outer .gs-themed wrapper added by postCompletionCard helper.
     Per docs/design/10-chat-cards.md §"Variant 4". --}}
<div class="gs-chat-card__header gs-chat-card__header--completion">
  <div class="gs-chat-card__speaker">
    <div class="gs-chat-card__portrait" aria-hidden="true">{{portraitInitial}}</div>
    <div class="gs-chat-card__speaker-stack">
      <span class="gs-chat-card__name gs-chat-card__name--completion">{{speakerName}}</span>
      <span class="gs-chat-card__subtitle">
        {{localize "GOODSOCIETY.chatCard.completion.hasResolved"}} {{possessive}} {{localize "GOODSOCIETY.chatCard.completion.innerConflict"}}
      </span>
    </div>
  </div>
  <span class="gs-chat-card__star" aria-hidden="true">★</span>
</div>
<hr class="gs-chat-card__rule">
<div class="gs-chat-card__body gs-chat-card__body--completion">
  <p class="gs-chat-card__conflict-labels">
    {{leftLabel}}
    <span class="gs-chat-card__vs">{{localize "GOODSOCIETY.chatCard.completion.vs"}}</span>
    {{rightLabel}}
  </p>
  <p class="gs-chat-card__resolved-on">
    {{localize "GOODSOCIETY.chatCard.completion.resolvedOn"}} {{resolvedLabel}}
  </p>
</div>
<hr class="gs-chat-card__rule">
<div class="gs-chat-card__footer gs-chat-card__footer--completion">
  <p class="gs-chat-card__earned-eyebrow">{{localize "GOODSOCIETY.chatCard.completion.earned"}}</p>
  <p class="gs-chat-card__earned-label">{{localize "GOODSOCIETY.chatCard.completion.backstoryAction"}}</p>
</div>
