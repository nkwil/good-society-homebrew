{{!-- Session Log Preview — single-root required by ApplicationV2 PARTS (§16 anti-pattern). --}}
<section class="gs-session-log-preview">

  {{!-- ── Header ─────────────────────────────────────────────────────────── --}}
  <header class="gs-session-log-preview__header">
    <div class="gs-session-log-preview__eyebrow-row">
      <div class="gs-session-log-preview__eyebrow-left">
        <span class="gs-gm-pill">GM</span>
        <span class="gs-session-log-preview__eyebrow">{{localize "GOODSOCIETY.sessionLog.eyebrow"}}</span>
      </div>
      <span class="gs-session-log-preview__autogenerated">{{localize "GOODSOCIETY.sessionLog.autogenerated"}}</span>
    </div>
    <h2 class="gs-session-log-preview__title">{{sessionTitle}}</h2>
    <p class="gs-session-log-preview__meta">{{metaLine}}</p>
  </header>

  {{!-- ── Body ─────────────────────────────────────────────────────────── --}}
  <div class="gs-session-log-preview__body">
    {{#if isEmpty}}
      <p class="gs-session-log-preview__empty">{{localize "GOODSOCIETY.sessionLog.emptyBody"}}</p>
    {{else if editMode}}
      <textarea class="gs-session-log-preview__editor">{{editedContent}}</textarea>
    {{else}}
      {{#each log.sections}}
        <div class="gs-session-log-preview__section">
          <header class="gs-section-header">{{label}}{{#if count}} · {{count}}{{/if}}</header>
          <div class="gs-hairline"></div>

          {{!-- Monologues — blockquote per entry --}}
          {{#if (eq type "monologue")}}
            {{#each entries}}
              <div class="gs-session-log-preview__monologue">
                <div class="gs-session-log-preview__monologue-meta">
                  <strong class="gs-session-log-preview__monologue-speaker">{{speakerName}}</strong>
                  <em class="gs-session-log-preview__monologue-time">{{time}}</em>
                </div>
                <blockquote class="gs-session-log-preview__monologue-body">{{content}}</blockquote>
              </div>
            {{/each}}

          {{!-- Reputation — tagged list with polarity arrows --}}
          {{else if (eq type "reputation")}}
            <ul class="gs-session-log-preview__rep-list">
              {{#each entries}}
                <li class="gs-session-log-preview__rep-entry">
                  {{#if (eq kind "tagAdded")}}
                    <strong>{{actorName}}</strong>
                    gained
                    <span class="gs-session-log-preview__arrow gs-session-log-preview__arrow--{{polarity}}">
                      {{#if (eq polarity "positive")}}▲{{else}}▼{{/if}}
                    </span>
                    {{tagName}}{{#if source}} — <em>{{source}}</em>{{/if}}
                  {{else if (eq kind "tagRemoved")}}
                    <strong>{{actorName}}</strong>
                    lost
                    <span class="gs-session-log-preview__arrow gs-session-log-preview__arrow--{{polarity}}">
                      {{#if (eq polarity "positive")}}▲{{else}}▼{{/if}}
                    </span>
                    {{tagName}}
                  {{else if (eq kind "conditionAdded")}}
                    ★ <strong>{{actorName}}</strong>: condition '{{conditionName}}' added
                  {{/if}}
                  <em class="gs-session-log-preview__time">({{time}})</em>
                </li>
              {{/each}}
            </ul>

          {{!-- Persona swaps — simple list --}}
          {{else if (eq type "personaSwap")}}
            <ul class="gs-session-log-preview__generic-list">
              {{#each entries}}
                <li>
                  <strong>{{actorName}}</strong> → {{personaName}}
                  <em class="gs-session-log-preview__time">({{time}})</em>
                </li>
              {{/each}}
            </ul>

          {{!-- Generic fallback (phase changes, etc.) --}}
          {{else}}
            <ul class="gs-session-log-preview__generic-list">
              {{#each entries}}
                <li>· {{text}} <em class="gs-session-log-preview__time">({{time}})</em></li>
              {{/each}}
            </ul>
          {{/if}}

        </div>
      {{/each}}
    {{/if}}
  </div>

  {{!-- ── Footer ─────────────────────────────────────────────────────────── --}}
  <footer class="gs-session-log-preview__footer">
    <div class="gs-session-log-preview__footer-left">
      {{#unless isEmpty}}
        {{#if editMode}}
          <button type="button" class="gs-btn gs-btn--secondary" data-action="previewMode">
            {{localize "GOODSOCIETY.sessionLog.previewBtn"}}
          </button>
        {{else}}
          <button type="button" class="gs-btn gs-btn--secondary" data-action="editMode">
            {{localize "GOODSOCIETY.sessionLog.editBtn"}}
          </button>
        {{/if}}
      {{/unless}}
      <em class="gs-session-log-preview__destination">→ {{destination}}</em>
    </div>
    <div class="gs-session-log-preview__footer-right">
      <button type="button" class="gs-btn gs-btn--ghost" data-action="cancel">
        {{localize "GOODSOCIETY.sessionLog.cancelBtn"}}
      </button>
      <button type="button" class="gs-btn gs-btn--primary" data-action="saveLog">
        {{localize "GOODSOCIETY.sessionLog.saveBtn"}}
      </button>
    </div>
  </footer>

</section>
