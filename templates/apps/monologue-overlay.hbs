{{!--
  Monologue scene-freeze overlay — post-MVP §12.2.
  Frameless full-viewport. Target's view edits the textarea; audience views
  see the read-only body live-syncing. GM sees the cancel pill.
--}}
<section class="gs-monologue-overlay gs-wi-stage">

  <div class="gs-wi-corners" aria-hidden="true">
    <span class="gs-wi-corner gs-wi-corner--tl"></span>
    <span class="gs-wi-corner gs-wi-corner--tr"></span>
    <span class="gs-wi-corner gs-wi-corner--bl"></span>
    <span class="gs-wi-corner gs-wi-corner--br"></span>
  </div>

  <div class="gs-wi-motes" aria-hidden="true">
    <span class="gs-wi-mote m1"></span>
    <span class="gs-wi-mote m3"></span>
    <span class="gs-wi-mote m5"></span>
  </div>

  <div class="gs-monologue-overlay__stack">
    <div class="gs-monologue-overlay__eyebrow">{{eyebrow}}</div>

    <div class="gs-monologue-overlay__cameo" aria-hidden="true">
      {{#if targetPortraitUrl}}
        <img src="{{targetPortraitUrl}}" alt="{{targetName}}" />
      {{else}}
        <span class="gs-monologue-overlay__cameo-initial">{{targetInitial}}</span>
      {{/if}}
    </div>

    <h2 class="gs-monologue-overlay__name">{{targetName}}</h2>
    {{#if targetRole}}
      <p class="gs-monologue-overlay__role">{{targetRole}}</p>
    {{/if}}

    {{#if question}}
      <p class="gs-monologue-overlay__question">"{{question}}"</p>
    {{/if}}

    {{#if isTarget}}
      <textarea class="gs-monologue-overlay__textarea"
                name="monologueBody"
                placeholder="{{localize 'GOODSOCIETY.tokenEvents.monologue.targetPlaceholder'}}"
                rows="6">{{body}}</textarea>
      <div class="gs-monologue-overlay__actions">
        <button type="button"
                class="gs-empty-state__action"
                data-action="submitMonologue">
          {{localize "GOODSOCIETY.tokenEvents.monologue.submit"}}
        </button>
      </div>
    {{else}}
      <textarea class="gs-monologue-overlay__textarea gs-monologue-overlay__readonly-body"
                name="monologueBody"
                rows="6"
                readonly>{{body}}</textarea>
      {{#if audienceLine}}
        <p class="gs-monologue-overlay__audience-line">{{audienceLine}}</p>
      {{/if}}
    {{/if}}

    {{#if isGM}}
      <div class="gs-monologue-overlay__gm-actions">
        <button type="button"
                class="gs-empty-state__action gs-monologue-overlay__cancel"
                data-action="cancelMonologue">
          {{localize "GOODSOCIETY.tokenEvents.monologue.cancel"}}
        </button>
      </div>
    {{/if}}
  </div>
</section>
