<section class="gs-phase-summary-modal">
  <header class="gs-phase-summary-modal__head">
    <span class="gs-eyebrow">{{localize "GOODSOCIETY.phaseSummary.eyebrow"}}</span>
    <h2 class="gs-phase-summary-modal__title">{{heading}}</h2>
    <p class="gs-phase-summary-modal__intro"><em>{{intro}}</em></p>
  </header>

  <div class="gs-phase-summary-modal__editor-wrap">
    <p class="gs-phase-summary-modal__edit-hint">{{editHint}}</p>
    <div class="gs-phase-summary-modal__editor"
         contenteditable="true"
         spellcheck="true">{{{summaryHtml}}}</div>
  </div>

  <footer class="gs-phase-summary-modal__foot">
    <button type="button" class="gs-btn gs-btn--ghost" data-action="cancelSummary">
      {{cancelLabel}}
    </button>
    <button type="button" class="gs-btn gs-btn--primary" data-action="postSummary">
      {{postLabel}}
    </button>
  </footer>
</section>
