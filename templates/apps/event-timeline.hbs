{{!-- Event Timeline — single root <section> required by ApplicationV2 PARTS.
     House-styled (no character theming — communal calendar surface). --}}
<section class="gs-event-timeline">

  {{!-- ── Header ─────────────────────────────────────────────────────── --}}
  <header class="gs-event-timeline__header">
    <h2 class="gs-event-timeline__title">{{localize "GOODSOCIETY.eventTimeline.heading"}}</h2>
    <div class="gs-event-timeline__current-row">
      <span class="gs-event-timeline__current-label">{{localize "GOODSOCIETY.eventTimeline.currentDateLabel"}}</span>
      {{#if editingDate}}
        <div class="gs-event-timeline__date-editor">
          <input type="number" data-date-field="year" value="{{currentDate.year}}" min="1000" max="9999" class="gs-event-timeline__num gs-event-timeline__num--year" />
          <input type="number" data-date-field="month" value="{{currentDate.month}}" min="1" max="12" class="gs-event-timeline__num" />
          <input type="number" data-date-field="day" value="{{currentDate.day}}" min="1" max="31" class="gs-event-timeline__num" />
          <button type="button" class="gs-btn gs-btn--sm gs-btn--primary" data-action="setDateSave">{{localize "GOODSOCIETY.eventTimeline.save"}}</button>
          <button type="button" class="gs-btn gs-btn--sm gs-btn--ghost" data-action="setDateCancel">{{localize "GOODSOCIETY.eventTimeline.cancel"}}</button>
        </div>
      {{else}}
        <span class="gs-event-timeline__current-date">{{currentDateLong}}</span>
        {{#if isGM}}
          <button type="button" class="gs-event-timeline__edit-link" data-action="setDateOpen" title="{{localize "GOODSOCIETY.eventTimeline.setDateHint"}}">
            {{localize "GOODSOCIETY.eventTimeline.editDate"}}
          </button>
        {{/if}}
      {{/if}}
    </div>
  </header>

  {{!-- ── Empty state ───────────────────────────────────────────────── --}}
  {{#unless hasAny}}
    <p class="gs-event-timeline__empty">
      {{#if isGM}}
        {{localize "GOODSOCIETY.eventTimeline.emptyGM"}}
      {{else}}
        {{localize "GOODSOCIETY.eventTimeline.emptyPlayer"}}
      {{/if}}
    </p>
  {{/unless}}

  {{!-- ── Upcoming ──────────────────────────────────────────────────── --}}
  {{#if upcoming.length}}
    <div class="gs-event-timeline__group">
      <div class="gs-event-timeline__group-eyebrow">{{localize "GOODSOCIETY.eventTimeline.upcoming"}}</div>
      {{#each upcoming}}
        {{> evt-row this editingId=../editingId isGM=../isGM choices=../visibilityChoices}}
      {{/each}}
    </div>
  {{/if}}

  {{!-- ── Today ─────────────────────────────────────────────────────── --}}
  {{#if today.length}}
    <div class="gs-event-timeline__group">
      <div class="gs-event-timeline__group-eyebrow gs-event-timeline__group-eyebrow--today">{{localize "GOODSOCIETY.eventTimeline.today"}}</div>
      {{#each today}}
        {{> evt-row this editingId=../editingId isGM=../isGM choices=../visibilityChoices}}
      {{/each}}
    </div>
  {{/if}}

  {{!-- ── Past ──────────────────────────────────────────────────────── --}}
  {{#if pastCount}}
    <div class="gs-event-timeline__group gs-event-timeline__group--past">
      <button type="button" class="gs-event-timeline__past-toggle" data-action="togglePast">
        {{#if showPast}}
          {{localize "GOODSOCIETY.eventTimeline.collapsePast"}} ({{pastCount}})
        {{else}}
          {{localize "GOODSOCIETY.eventTimeline.expandPast"}} ({{pastCount}})
        {{/if}}
      </button>
      {{#if showPast}}
        {{#each past}}
          {{> evt-row this editingId=../editingId isGM=../isGM choices=../visibilityChoices}}
        {{/each}}
      {{/if}}
    </div>
  {{/if}}

  {{!-- ── Add event row (GM only) ──────────────────────────────────── --}}
  {{#if isGM}}
    <div class="gs-event-timeline__add-row">
      {{#if addingEvent}}
        <div class="gs-event-timeline__form">
          <div class="gs-event-timeline__form-row">
            <label class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.titleLabel"}}</label>
            <input type="text" data-evt-field="title" class="gs-event-timeline__input" placeholder="{{localize "GOODSOCIETY.eventTimeline.titlePlaceholder"}}" />
          </div>
          <div class="gs-event-timeline__form-row gs-event-timeline__form-row--inline">
            <label class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.dateLabel"}}</label>
            <input type="number" data-evt-field="year" value="{{currentDate.year}}" min="1000" max="9999" class="gs-event-timeline__num gs-event-timeline__num--year" />
            <input type="number" data-evt-field="month" value="{{currentDate.month}}" min="1" max="12" class="gs-event-timeline__num" />
            <input type="number" data-evt-field="day" value="{{currentDate.day}}" min="1" max="31" class="gs-event-timeline__num" />
          </div>
          <div class="gs-event-timeline__form-row">
            <label class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.descriptionLabel"}}</label>
            <textarea data-evt-field="description" class="gs-event-timeline__textarea" rows="3"></textarea>
          </div>
          <div class="gs-event-timeline__form-row gs-event-timeline__form-row--vis">
            <span class="gs-event-timeline__label">{{localize "GOODSOCIETY.eventTimeline.visibilityLabel"}}</span>
            {{#each visibilityChoices}}
              <label class="gs-event-timeline__radio">
                <input type="radio" data-evt-field="visibility" value="{{value}}" {{#if @first}}checked{{/if}} />
                <span>{{label}}</span>
              </label>
            {{/each}}
          </div>
          <div class="gs-event-timeline__form-actions">
            <button type="button" class="gs-btn gs-btn--ghost" data-action="addEventCancel">{{localize "GOODSOCIETY.eventTimeline.cancel"}}</button>
            <button type="button" class="gs-btn gs-btn--primary" data-action="addEventSave">{{localize "GOODSOCIETY.eventTimeline.saveEvent"}}</button>
          </div>
        </div>
      {{else}}
        <button type="button" class="gs-btn gs-btn--outline gs-event-timeline__add-btn" data-action="addEventOpen">
          + {{localize "GOODSOCIETY.eventTimeline.addEvent"}}
        </button>
      {{/if}}
    </div>
  {{/if}}

</section>
