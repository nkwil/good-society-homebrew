<section class="gs-npc-organizer {{#if minimized}}is-minimized{{/if}}">
  <header class="gs-npc-organizer__header">
    <div class="gs-npc-organizer__header-top">
      <span class="gs-gm-pill">GM</span>
      <span class="gs-npc-organizer__eyebrow">{{localize "GOODSOCIETY.npcOrganizer.eyebrow"}}</span>
      <span class="gs-npc-organizer__total">{{total}}</span>
      <button type="button"
              class="gs-npc-organizer__minimize"
              data-action="toggle-minimize"
              aria-label="{{#if minimized}}{{localize 'GOODSOCIETY.npcOrganizer.expand'}}{{else}}{{localize 'GOODSOCIETY.npcOrganizer.minimize'}}{{/if}}"
              title="{{#if minimized}}{{localize 'GOODSOCIETY.npcOrganizer.expand'}}{{else}}{{localize 'GOODSOCIETY.npcOrganizer.minimize'}}{{/if}}">
        {{#if minimized}}+{{else}}−{{/if}}
      </button>
    </div>
    {{#if sceneName}}
    <div class="gs-npc-organizer__scene-name">{{sceneName}}</div>
    {{/if}}
  </header>

  <div class="gs-npc-organizer__body">
    {{#unless total}}
    <p class="gs-npc-organizer__empty">{{localize "GOODSOCIETY.npcOrganizer.empty"}}</p>
    {{else}}
      {{#if connections.length}}
      <div class="gs-npc-organizer__section">
        <div class="gs-npc-organizer__section-eyebrow">
          {{localize "GOODSOCIETY.npcOrganizer.connectionsLabel"}} · {{connections.length}}
        </div>
        {{#each connections}}
        <div class="gs-npc-organizer__row gs-themed"
          data-theme="{{theme}}"
          data-token-id="{{tokenId}}"
          data-actor-id="{{actorId}}"
          title="{{tokenName}}"
        >
          <div class="gs-npc-organizer__row-portrait">
            {{#if portraitUrl}}
            <img class="gs-npc-organizer__row-img" src="{{portraitUrl}}" alt="" />
            {{else}}
            <span class="gs-npc-organizer__row-initial">{{portraitInitial}}</span>
            {{/if}}
          </div>
          <div class="gs-npc-organizer__row-text">
            <div class="gs-npc-organizer__row-name">{{tokenName}}</div>
            {{#if title}}
              <div class="gs-npc-organizer__row-title"><em>{{title}}</em></div>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if npcs.length}}
      <div class="gs-npc-organizer__section">
        <div class="gs-npc-organizer__section-eyebrow">
          {{localize "GOODSOCIETY.npcOrganizer.npcsLabel"}} · {{npcs.length}}
        </div>
        {{#each npcs}}
        <div class="gs-npc-organizer__row gs-themed"
          data-theme="npc"
          data-token-id="{{tokenId}}"
          data-actor-id="{{actorId}}"
          title="{{tokenName}}"
        >
          <div class="gs-npc-organizer__row-portrait">
            {{#if portraitUrl}}
            <img class="gs-npc-organizer__row-img" src="{{portraitUrl}}" alt="" />
            {{else}}
            <span class="gs-npc-organizer__row-initial">{{portraitInitial}}</span>
            {{/if}}
          </div>
          <div class="gs-npc-organizer__row-text">
            <div class="gs-npc-organizer__row-name">{{tokenName}}</div>
            {{#if title}}
              <div class="gs-npc-organizer__row-title"><em>{{title}}</em></div>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}
    {{/unless}}
  </div>

  <footer class="gs-npc-organizer__footer">
    {{localize "GOODSOCIETY.npcOrganizer.footerHint"}}
  </footer>
</section>
