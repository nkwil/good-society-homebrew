{{!-- Actions You Can Take — single root required by ApplicationV2 PARTS. --}}
<section class="gs-cheat-sheet">
  <div class="gs-cheat-sheet__layout">

    {{!-- Left: table of contents --}}
    <nav class="gs-cheat-sheet__toc">
      <h3 class="gs-cheat-sheet__toc-heading">{{localize "GOODSOCIETY.actionsCheatSheet.tocHeading"}}</h3>
      <ol class="gs-cheat-sheet__toc-list">
        <li><a href="#acs-trade">{{localize "GOODSOCIETY.actionsCheatSheet.s1.tocLabel"}}</a></li>
        <li><a href="#acs-spend">{{localize "GOODSOCIETY.actionsCheatSheet.s2.tocLabel"}}</a></li>
        <li><a href="#acs-negotiate">{{localize "GOODSOCIETY.actionsCheatSheet.s3.tocLabel"}}</a></li>
        <li><a href="#acs-earn">{{localize "GOODSOCIETY.actionsCheatSheet.s4.tocLabel"}}</a></li>
        <li><a href="#acs-conditions">{{localize "GOODSOCIETY.actionsCheatSheet.s5.tocLabel"}}</a></li>
        <li><a href="#acs-monologue">{{localize "GOODSOCIETY.actionsCheatSheet.s6.tocLabel"}}</a></li>
      </ol>
    </nav>

    {{!-- Right: content --}}
    <main class="gs-cheat-sheet__body">

      <section class="gs-cheat-sheet__section" id="acs-trade">
        <h4 class="gs-cheat-sheet__section-heading">
          {{localize "GOODSOCIETY.actionsCheatSheet.s1.heading"}}
          <span class="gs-cheat-sheet__page-ref">{{localize "GOODSOCIETY.actionsCheatSheet.s1.pageRef"}}</span>
        </h4>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s1.body"}}</p>
        <ul>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s1.positive"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s1.negative"}}</li>
        </ul>
      </section>

      <section class="gs-cheat-sheet__section" id="acs-spend">
        <h4 class="gs-cheat-sheet__section-heading">
          {{localize "GOODSOCIETY.actionsCheatSheet.s2.heading"}}
          <span class="gs-cheat-sheet__page-ref">{{localize "GOODSOCIETY.actionsCheatSheet.s2.pageRef"}}</span>
        </h4>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s2.intro"}}</p>
        <ul>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s2.bullet1"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s2.bullet2"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s2.bullet3"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s2.bullet4"}}</li>
        </ul>
        <p class="gs-cheat-sheet__aside">{{localize "GOODSOCIETY.actionsCheatSheet.s2.noToken"}}</p>
      </section>

      <section class="gs-cheat-sheet__section" id="acs-negotiate">
        <h4 class="gs-cheat-sheet__section-heading">
          {{localize "GOODSOCIETY.actionsCheatSheet.s3.heading"}}
          <span class="gs-cheat-sheet__page-ref">{{localize "GOODSOCIETY.actionsCheatSheet.s3.pageRef"}}</span>
        </h4>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s3.triggers"}}</p>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s3.responses"}}</p>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s3.refused"}}</p>
      </section>

      <section class="gs-cheat-sheet__section" id="acs-earn">
        <h4 class="gs-cheat-sheet__section-heading">
          {{localize "GOODSOCIETY.actionsCheatSheet.s4.heading"}}
          <span class="gs-cheat-sheet__page-ref">{{localize "GOODSOCIETY.actionsCheatSheet.s4.pageRef"}}</span>
        </h4>
        <ul>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s4.bullet1"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s4.bullet2"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s4.bullet3"}}</li>
          <li>{{localize "GOODSOCIETY.actionsCheatSheet.s4.bullet4"}}</li>
        </ul>
      </section>

      <section class="gs-cheat-sheet__section" id="acs-conditions">
        <h4 class="gs-cheat-sheet__section-heading">
          {{localize "GOODSOCIETY.actionsCheatSheet.s5.heading"}}
          <span class="gs-cheat-sheet__page-ref">{{localize "GOODSOCIETY.actionsCheatSheet.s5.pageRef"}}</span>
        </h4>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s5.body"}}</p>
        <p class="gs-cheat-sheet__aside">{{localize "GOODSOCIETY.actionsCheatSheet.s5.noCancel"}}</p>
      </section>

      <section class="gs-cheat-sheet__section" id="acs-monologue">
        <h4 class="gs-cheat-sheet__section-heading">
          {{localize "GOODSOCIETY.actionsCheatSheet.s6.heading"}}
          <span class="gs-cheat-sheet__page-ref">{{localize "GOODSOCIETY.actionsCheatSheet.s6.pageRef"}}</span>
        </h4>
        <p>{{localize "GOODSOCIETY.actionsCheatSheet.s6.body"}}</p>
      </section>

    </main>
  </div>
</section>
