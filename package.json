{
  "name": "good-society-homebrew",
  "version": "0.1.0",
  "description": "A homebrew Good Society TTRPG variant for Foundry VTT v13",
  "scripts": {
    "build": "sass src/scss/boilerplate.scss css/boilerplate.css --style=expanded --no-source-map",
    "watch": "sass src/scss/boilerplate.scss css/boilerplate.css --style=expanded --source-map --watch",
    "generate": "node src/generate-boilerplate-system.mjs"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Opal",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "^13.346.0-beta.20250812191140",
    "glob": "^10.3.10",
    "inquirer": "^9.2.15",
    "prompt": "^1.3.0",
    "renamer": "^5.0.0",
    "replace": "^1.2.2",
    "sass": "^1.53.0"
  }
}
